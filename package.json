{
  "name": "lanpai-overlay",
  "version": "0.3.1",
  "description": "Transparent on-screen overlay for text and images",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "electron smoke-main.js",
    "release": "electron-builder --win --publish never",
    "icon": "node scripts/gen-icon.js",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.jeffrey0117.lanpai-overlay",
    "productName": "Lanpai Overlay",
    "icon": "assets/icon-256.png",
    "files": [
      "main.js",
      "preload.js",
      "overlay.html",
      "overlay.js",
      "toolbar.js",
      "board.js",
      "history.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "懶拍 Overlay",
      "artifactName": "Lanpai-Overlay-${version}-Setup.exe"
    },
    "portable": {
      "artifactName": "Lanpai-Overlay-${version}-portable.exe"
    }
  }
}
